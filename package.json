{
  "name": "antigravity-autorun",
  "displayName": "Antigravity Autorun",
  "description": "True hands-free automation for Antigravity Agent using lightning-fast CDP Network sniffing and Direct API interactions.",
  "version": "3.0.0",
  "publisher": "njk",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "antigravity",
    "autorun",
    "automation",
    "cdp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-autorun.toggle",
        "title": "Antigravity Autorun: Toggle ON/OFF"
      },
      {
        "command": "antigravity-autorun.reconnect",
        "title": "Antigravity Autorun: Reconnect CDP"
      },
      {
        "command": "antigravity-autorun.restartWithCDP",
        "title": "Antigravity Autorun: Restart Antigravity with CDP"
      },
      {
        "command": "antigravity-autorun.diagnose",
        "title": "Antigravity Autorun: Diagnose CDP Connection"
      }
    ],
    "configuration": {
      "title": "Antigravity Autorun",
      "properties": {
        "antigravityAutorun.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable autorun on startup"
        },
        "antigravityAutorun.antigravityPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Antigravity executable. Leave blank for auto-detection."
        },
        "antigravityAutorun.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "CDP port (9222 or 9333)"
        },
        "antigravityAutorun.delay": {
          "type": "number",
          "default": 100,
          "description": "Delay in ms before clicking (for throttling)"
        },
        "antigravityAutorun.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scroll to hidden buttons"
        },
        "antigravityAutorun.blockedCommands": {
          "type": "array",
          "default": [
            "rm -rf /",
            "sudo rm",
            "format",
            "del /"
          ],
          "description": "Commands to never autorun"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/integralink/antigravity-autorun"
  },
  "license": "MIT"
}
